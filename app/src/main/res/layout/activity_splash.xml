<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/splash_bg"
    android:padding="40dp">

    <!-- Icon inside white circle -->
    <FrameLayout
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_marginBottom="28dp">

        <!-- White circle background -->
        <View
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:background="@drawable/icon_circle" />

        <!-- App icon on top -->
        <ImageView
            android:id="@+id/splashLogo"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_launcher"
            android:contentDescription="4G LTE Icon"
            android:scaleType="fitCenter" />
    </FrameLayout>

    <!-- App name -->
    <TextView
        android:id="@+id/splashAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="4G LTE"
        android:textSize="48sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:letterSpacing="0.15"
        android:layout_marginBottom="6dp" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Radio Info"
        android:textSize="16sp"
        android:textColor="@color/accent_blue_light"
        android:letterSpacing="0.3"
        android:layout_marginBottom="60dp" />

    <!-- Tagline at bottom -->
    <TextView
        android:id="@+id/splashTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Made with love by AS"
        android:textSize="13sp"
        android:textColor="@color/text_muted" />

</LinearLayout>
