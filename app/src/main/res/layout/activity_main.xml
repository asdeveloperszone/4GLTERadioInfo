<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── TOP HEADER BANNER ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="32dp"
            android:paddingBottom="24dp"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:background="@color/bg_dark">

            <!-- Icon in white circle -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginBottom="14dp">

                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/icon_circle" />

                <ImageView
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_launcher"
                    android:contentDescription="4G LTE"
                    android:scaleType="fitCenter" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4G LTE"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Radio Info Guide"
                android:textSize="13sp"
                android:textColor="@color/accent_blue_light"
                android:letterSpacing="0.2" />

        </LinearLayout>

        <!-- ── DIVIDER ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp" />

        <!-- ── CONTENT PADDING WRAPPER ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── WHAT IS LTE CARD ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#0F2442"
                app:cardElevation="0dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:text="4G"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:background="@drawable/step_circle"
                        android:layout_marginEnd="14dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="What is LTE Only Mode"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Forces your phone to connect only to 4G LTE towers, skipping slower 3G and 2G networks for faster, stable internet speed."
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:lineSpacingMultiplier="1.4" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── SECTION LABEL ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOW TO SET LTE ONLY"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/accent_blue_light"
                android:letterSpacing="0.15"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="10dp"
                android:layout_marginLeft="4dp" />

            <!-- ── STEP 1 ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#0A1C35"
                app:cardElevation="0dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:text="1"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:background="@drawable/step_circle"
                        android:layout_marginEnd="14dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap Continue below"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="3dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Opens the hidden Radio Info settings screen inside your phone."
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:lineSpacingMultiplier="1.4" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── STEP 2 ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#0A1C35"
                app:cardElevation="0dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:text="2"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:background="@drawable/step_circle"
                        android:layout_marginEnd="14dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scroll to Preferred Network Type"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="3dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="In Radio Info screen, scroll down to find the network type dropdown selector."
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:lineSpacingMultiplier="1.4" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── STEP 3 ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#0A1C35"
                app:cardElevation="0dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:text="3"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:background="@drawable/step_circle"
                        android:layout_marginEnd="14dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select LTE Only"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="3dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Choose LTE only or LTE/CDMA from the dropdown to lock your device to 4G."
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:lineSpacingMultiplier="1.4" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── STEP 4 ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#0A1C35"
                app:cardElevation="0dp"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:text="4"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:background="@drawable/step_circle"
                        android:layout_marginEnd="14dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Restart your phone"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="3dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Reboot to apply changes. Your device will always stay on 4G LTE network."
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:lineSpacingMultiplier="1.4" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── WARNING BOX ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#0A1F38"
                app:cardElevation="0dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:text="!"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/bg_dark"
                            android:gravity="center"
                            android:background="@drawable/step_circle"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Important Note"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/warning_yellow" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LTE Only mode will block 3G and 2G fallback. In areas with weak 4G signal you may lose calls or data. Switch back to Automatic if needed."
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:lineSpacingMultiplier="1.5" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── CONTINUE BUTTON ── -->
            <Button
                android:id="@+id/btnContinue"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Open Radio Info Settings"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/btn_ripple"
                android:layout_marginBottom="10dp" />

            <!-- ── FOOTER ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Made with love by AS"
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:gravity="center"
                android:paddingTop="4dp"
                android:paddingBottom="16dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
